local function createDungeonSection(tab, opts)
  local section = tab:Section({ Title = opts.title })
  local resetFreeEnabled = false
  local checkValue = opts.defaultCheck or "30"

  section:Dropdown({
  Title = "Checkpoint",
  Values = {"30","60","90","120","150","180","210","240","270","300","330","360","390","420","450","480","510","540","570","600","630","660","690","720","750","780","810","840","870","900","930","960","990","1020","1050","1080","1110","1140","1170","1200","1230","1260","1290","1320","1350","1380","1410","1440","1470","1500"},
  Default = checkValue,

  Callback = function(val) checkValue = val end
  })

  local function triggerReset()
    safeFireRemote({{ { Event = opts.event, Action = "Create" }, key }})
    task.wait(0.5)
    if opts.event == "InfiniteModeAction" then
      safeFireRemote({{ { Check = checkValue, Action = "Start", Event = opts.event }, key }})
    else
      safeFireRemote({{ { Dungeon = LocalPlayer.UserId, Event = opts.event, Action = "Start" }, key }})
    end
  end

  section:Button({
  Title = "Join / Create " .. opts.title,

  Callback = function()
    triggerReset()
    notify("Started", opts.title .. " at checkpoint " .. checkValue, "play", "Green", 4)
  end
  })

  section:Toggle({
  Title = "Reset Free",
  Value = false,

  Callback = function(state) resetFreeEnabled = state end
  })

  section:Toggle({
  Title = "Stand in Middle",
  Value = false,

  Callback = function(state)
    if game.PlaceId ~= opts.placeId then return end
    if cachedRoot then
      if state then
        cachedRoot.CFrame = CFrame.new(opts.middlePos)
        cachedRoot.Anchored = true
      else
        cachedRoot.Anchored = false
      end
    end
  end
  })

  ReplicatedStorage:GetAttributeChangedSignal("PortalHealth"):Connect(function()
    if resetFreeEnabled then
      local portalHealth = ReplicatedStorage:GetAttribute("PortalHealth")
      if portalHealth == 0 or portalHealth == nil then
        triggerReset()
        notify("Reset Free", opts.title .. " auto restarted at checkpoint " .. checkValue, "refresh-cw", "Green", 3)
        task.wait(2)
      end
    end
  end)
end

