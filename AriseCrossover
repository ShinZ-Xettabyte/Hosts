local autoFarmEnabled = false
local enemiesFolder = Workspace:WaitForChild("__Main"):WaitForChild("__Enemies"):WaitForChild("Server")

local function getNearestEnemy()
  if not cachedRoot then return nil end
  local nearest, minDist = nil, math.huge
  local rootPos = cachedRoot.Position

  for _, enemy in ipairs(enemiesFolder:GetChildren()) do
    if enemy:IsA("BasePart") then
      local dist = (rootPos - enemy.Position).Magnitude
      if dist < minDist then
        minDist = dist
        nearest = enemy
      end
    end
  end
  return nearest
end

task.spawn(function()
  while task.wait(0.1) do
    if autoFarmEnabled and cachedRoot then
      local target = getNearestEnemy()
      if target then
        local offset = -target.CFrame.LookVector * 4 + Vector3.new(0, 3.5, 0)
        cachedRoot.CFrame = target.CFrame * CFrame.new(offset)
      end
    end
  end
end)

