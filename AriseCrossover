local function createCastleSection(tab, opts)
    local section = tab:Section({Title = opts.title})
    states.resetFreeEnabled[opts.title] = false
    local checkValue = opts.defaultCheck or "30"
    states.castleDropdowns[opts.title] =
        section:Dropdown(
        {
            Title = "Checkpoint",
            Values = checkpointValues,
            Default = checkValue,
            Flag = opts.title .. "_Checkpoint",
            Callback = function(val)
                checkValue = val
            end
        }
    )
    local function triggerReset()
        safeFireRemote({{{Event = opts.event, Action = "Create"}, key}})
        task.wait(0.5)
        if opts.event == "InfiniteModeAction" then
            safeFireRemote({{{Check = checkValue, Action = "Start", Event = opts.event}, key}})
        else
            safeFireRemote({{{Dungeon = LocalPlayer.UserId, Event = opts.event, Action = "Start"}, key}})
        end
    end
    section:Button(
        {Title = "Join / Create " .. opts.title, Callback = function()
                triggerReset()
                notify("Started", opts.title .. " at checkpoint " .. checkValue, "play", "Green", 4)
            end}
    )
    section:Toggle(
        {Title = "Reset Free", Value = false, Flag = opts.title .. "_ResetFree", Callback = function(state)
                states.resetFreeEnabled[opts.title] = state
            end}
    )
    section:Toggle(
        {Title = "Stand in Middle", Value = false, Flag = opts.title .. "Stand_Middle", Callback = function(state)
                if game.PlaceId ~= opts.placeId or not cachedRoot then
                    return
                end
                if state then
                    cachedRoot.CFrame = CFrame.new(opts.middlePos)
                    cachedRoot.Anchored = true
                else
                    cachedRoot.Anchored = false
                end
            end}
    )
    ReplicatedStorage:GetAttributeChangedSignal("PortalHealth"):Connect(
        function()
            if not states.resetFreeEnabled[opts.title] then
                return
            end
            local portalHealth = ReplicatedStorage:GetAttribute("PortalHealth")
            if portalHealth == 0 or portalHealth == nil then
                triggerReset()
                notify("Reset Free", opts.title .. " auto restarted", "refresh-cw", "Green", 3)
                task.wait(2)
            end
        end
    )
end
